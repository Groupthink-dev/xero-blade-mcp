# Xero OAuth2 credentials (Custom Connection — recommended for MCP)
XERO_CLIENT_ID=your_client_id
XERO_CLIENT_SECRET=your_client_secret

# Or: pre-obtained access token (testing/short-lived only)
# XERO_ACCESS_TOKEN=your_access_token

# Tenant selection (required — get from xero_connections tool)
# XERO_TENANT_ID=your_tenant_id

# Write gate — must be "true" to enable create/update/delete/void operations
XERO_WRITE_ENABLED=false

# Webhook verification secret (from Xero webhook subscription)
# XERO_WEBHOOK_KEY=your_webhook_key

# Transport mode: "stdio" (default) or "http"
# XERO_MCP_TRANSPORT=stdio
# XERO_MCP_HOST=127.0.0.1
# XERO_MCP_PORT=8770
# XERO_MCP_API_TOKEN=your_bearer_token
